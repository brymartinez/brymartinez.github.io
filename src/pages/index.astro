---

<BaseLayout title="Bryan Louie Martinez">
  <section class="hero">
    <h1>Bryan Louie Martinez</h1>
    <p class="eyebrow">Barcelona, Spain</p>
    <p>
      Senior software engineer and tech lead with several years of experience in
      designing cloud-native event-driven systems, APIs, and automation
      pipelines across multiple languages and platforms.
    </p>
    <div class="button-row">
      <a class="button button-primary" href="/projects">View notable projects</a
      >
      <a class="button button-primary" href="/notes">Read notes</a>
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">Core Technologies</p>
    <div class="profile-list">
      <div>
        <strong>Languages</strong>
        <span>Go, TypeScript, Node.js, Python, PHP</span>
      </div>
      <div>
        <strong>Cloud Platforms</strong>
        <span>AWS, Google Cloud Platform</span>
      </div>
      <div>
        <strong>Infrastructure</strong>
        <span>Terraform, Docker</span>
      </div>
      <div>
        <strong>Databases</strong>
        <span>PostgreSQL, DynamoDB, MongoDB, MySQL</span>
      </div>
      <div>
        <strong>Architecture</strong>
        <span>Microservices, Event-Driven Systems, API Design</span>
      </div>
      <div>
        <strong>DevOps</strong>
        <span
          >Google Cloud Build, AWS Pipeline, GitHub Actions, GitLab CI, Jenkins</span
        >
      </div>
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">CV</p>
    <div class="timeline">
      {
        experiences.map((experience) => (
          <article class="timeline-item">
            <p class="eyebrow">{experience.period}</p>
            <h3>{experience.role}</h3>
            <p class="timeline-company">{experience.company}</p>
            <div class="tag-list">
              {experience.technologies.map((technology) => (
                <span class="tag">{technology}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
