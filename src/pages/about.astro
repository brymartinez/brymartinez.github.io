---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Bry Martinez">
  <section class="section prose">
    <p class="eyebrow">About</p>
    <h1>About this site</h1>
    <p>
      Use this page for your bio, what you work on, what you are learning, and
      what readers can expect from the site.
    </p>
    <p>
      Because this is Astro, you can keep pages like this hand-written and
      simple while letting your blog and notes grow through content files.
    </p>
  </section>
</BaseLayout>

