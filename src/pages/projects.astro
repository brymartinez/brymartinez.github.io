---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects | Bryan Louie Martinez">
  <section class="section">
    <p class="eyebrow">Projects</p>
    <h1>Projects and diagrams</h1>
    <p>
      Use this page as a simple project index. Each card can represent a system,
      architecture diagram, case study, or experiment you want to show.
    </p>

    <div class="card-grid">
      <article class="card">
        <p class="eyebrow">Diagram</p>
        <h2>System architecture</h2>
        <p>Summarize a platform, service flow, or integration map here.</p>
      </article>
      <article class="card">
        <p class="eyebrow">Case study</p>
        <h2>Implementation overview</h2>
        <p>Explain the problem, approach, and tradeoffs in a compact format.</p>
      </article>
      <article class="card">
        <p class="eyebrow">Reference</p>
        <h2>Link to related notes</h2>
        <p>Connect each project to the notes section when you want deeper detail.</p>
      </article>
    </div>
  </section>
</BaseLayout>
