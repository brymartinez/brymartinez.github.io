---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Bry Martinez writes about software, projects, and technical notes."
} = Astro.props;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/notes", label: "Notes" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href="/">Bry Martinez</a>
        <nav aria-label="Primary">
          <ul class="nav-list">
            {navItems.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </header>

      <main class="page-content">
        <slot />
      </main>

      <footer class="site-footer">
        <p>Built with Astro. Hosted free on GitHub Pages.</p>
      </footer>
    </div>
  </body>
</html>

